DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_TIME_ZONE=UTC
DJANGO_SITE_DOMAIN=127.0.0.1:8000
DJANGO_SITE_NAME=AI Medical Assistant
DJANGO_USE_X_FORWARDED_HOST=true
DJANGO_SECURE_PROXY_SSL_HEADER=true

# Database
DATABASE_URL=
DJANGO_DB_CONN_MAX_AGE=600
DJANGO_DB_SSL_REQUIRE=false
DJANGO_SQLITE_PATH=

# OTP and email delivery
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@aimedical.local
DJANGO_EMAIL_HOST=smtp.example.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false
DJANGO_DEFAULT_PHONE_COUNTRY_CODE=+91

# SMS delivery
DJANGO_SMS_BACKEND=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Security toggles for deployment
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_STATIC_ROOT=
DJANGO_MEDIA_ROOT=
DJANGO_SERVE_MEDIA=false
DJANGO_MODEL_ARTIFACT_ROOT=
DJANGO_INLINE_TRAINING_WORKER=false
DJANGO_INLINE_TRAINING_WORKER_POLL_SECONDS=15

# AI integrations
GROQ_API_KEY=
REGISTRATION_OTP_EXPIRY_MINUTES=10
REGISTRATION_OTP_MAX_ATTEMPTS=5
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional runtime tuning
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=180
TRAINING_WORKER_POLL_SECONDS=15
